# SDD Overnight Automation Configuration
# Copy this to .env.local and customize

# ─────────────────────────────────────────────
# Slack Configuration
# ─────────────────────────────────────────────

# Channel to scan for feature requests
SLACK_FEATURE_CHANNEL="#feature-requests"

# Keywords to search for in Slack (comma-separated)
SLACK_SEARCH_KEYWORDS="feature request,can we add,would be nice,bug,improvement"

# How many days back to search
SLACK_LOOKBACK_DAYS=7

# Channel to post completion reports (optional)
SLACK_REPORT_CHANNEL="#dev-updates"

# ─────────────────────────────────────────────
# Jira Configuration
# ─────────────────────────────────────────────

# Jira Cloud ID (your-site.atlassian.net or UUID)
JIRA_CLOUD_ID=

# Jira project key (e.g., PROJ, MYAPP)
JIRA_PROJECT_KEY=

# Label that marks issues as ready for auto-implementation
JIRA_AUTO_LABEL=auto-ok

# Issue type to create for new features
JIRA_ISSUE_TYPE=Story

# ─────────────────────────────────────────────
# Integration Options
# ─────────────────────────────────────────────

# Create Jira tickets for Slack requests
CREATE_JIRA_FOR_SLACK=true

# Create Jira tickets for /clone-app features
CREATE_JIRA_FOR_ROADMAP=false

# Keep Jira status in sync with roadmap
SYNC_JIRA_STATUS=true

# Reply to Slack when feature is completed
SLACK_NOTIFY_COMPLETE=true

# ─────────────────────────────────────────────
# Automation Settings
# ─────────────────────────────────────────────

# CLI provider for build scripts (cursor | claude)
# - cursor: Cursor CLI (agent) — default
# - claude: Claude Code CLI
# Model names differ: Cursor uses composer-1.5, sonnet-4.5; Claude uses claude-sonnet-4-5, etc.
CLI_PROVIDER=cursor

# Maximum features to build per run
# - build-loop-local: default 50 (interactive)
# - overnight-autonomous: default 4 (unattended, shorter runs)
MAX_FEATURES=50

# Retries per feature when build/test fails (build-loop-local only)
MAX_RETRIES=3

# Hours of commits to review for learnings
HOURS_BACK=24

# Create draft PRs automatically (requires gh CLI)
CREATE_PR_ON_COMPLETE=true

# Base branch to sync from and create feature branches from
# - Unset (build-loop): use current branch when you run the script
# - develop: always use develop
# - main: always use main (overnight default)
# - current (overnight only): use whatever branch you're on when script starts
BASE_BRANCH=

# Branch strategy for build scripts (chained|independent|both|sequential|parallel)
# - chained: Each feature branches from previous feature (default)
#            Feature #2 has Feature #1's code even if not merged
# - independent: Each feature in a separate git worktree from BASE_BRANCH (isolated)
# - both: Run chained first, then rebuild each feature independently
#         (sequential, not parallel — runs one after the other)
# - sequential: All features on one branch (build-loop-local only)
# - parallel: Build multiple features simultaneously in separate worktrees
#             Each feature branches from BASE_BRANCH, then merges to integration branch
BRANCH_STRATEGY=chained

# Parallel build settings (only used when BRANCH_STRATEGY=parallel)
# Max concurrent agent processes (each gets its own worktree)
PARALLEL_FEATURES=3
# Merge strategy for collecting parallel results:
# - dependency: Merge in dependency order (recommended — respects roadmap Deps column)
# - fifo: Merge in completion order (first done, first merged)
MERGE_STRATEGY=dependency

# Spec↔code drift checking after each feature build (Phase 4)
# When enabled, a SEPARATE agent reads the spec and source files after the
# build+refactor agent commits, comparing them with fresh context ("Layer 2" check).
# The build agent also does a self-check ("Layer 1") as part of Phase 2.
DRIFT_CHECK=true

# How many times to retry auto-fixing drift (default: 2)
# If drift is found, the drift agent updates specs to match code.
# If the fix breaks the build, it retries up to this many times.
MAX_DRIFT_RETRIES=2

# Refactor phase (Phase 3) — clean up code after tests pass
# A fresh agent reads the source files and applies refactoring (extract functions,
# simplify, improve naming, etc.) while ensuring tests still pass.
# If refactor breaks build/tests, it's automatically reverted.
REFACTOR=true

# Compound phase (Phase 5) — extract learnings after drift check
# A fresh agent captures feature-specific and cross-cutting learnings
# into spec files and .specs/learnings/.
COMPOUND=true

# ─────────────────────────────────────────────
# Build Validation
# ─────────────────────────────────────────────

# All check commands are auto-detected from project files if left empty.
# Set to "skip" to explicitly disable a check.
# Empty commands are re-detected after each feature (handles greenfield bootstrap
# where Feature 1 creates the project infrastructure that didn't exist at startup).
# Newly detected commands are persisted back to .env.local.

# Build check command (auto-detected: tsc, cargo check, go build, npm run build, etc.)
BUILD_CHECK_CMD=""

# Test check command (auto-detected: npm test, pytest, cargo test, go test, etc.)
TEST_CHECK_CMD=""

# Lint check command (auto-detected: npm run lint, ruff check, cargo clippy, etc.)
# Non-blocking — warns but doesn't trigger retry.
LINT_CHECK_CMD=""

# Migration command (auto-detected: drizzle-kit push, prisma db push, alembic upgrade, etc.)
# Only runs when schema files change (detected via git diff).
# Non-blocking — warns if migration fails (database may not be available).
MIGRATION_CMD=""

# E2E test command (auto-detected: playwright, cypress)
# Runs after drift check (most expensive, needs final code).
# Non-blocking — warns but doesn't trigger retry.
E2E_CHECK_CMD=""

# Post-build validation steps (comma-separated)
# Available: test, code-review
# - test: Run test suite after build AND after refactor (failures trigger retry)
# - code-review: Run /code-review agent in fresh context (non-blocking)
# Note: refactor, drift, and compound are separate phases (not post-build steps).
POST_BUILD_STEPS="test"

# ─────────────────────────────────────────────
# Model Selection (Cursor CLI default)
# ─────────────────────────────────────────────

# Each agent step gets a fresh context window. You can use different
# models for each step (e.g., powerful model for building, cheaper for validation).
# Run `agent --list-models` to see available models.

# Default model for all agent steps (composer-1.5 recommended; empty = Cursor CLI default)
AGENT_MODEL="composer-1.5"

# Per-step overrides (fall back to AGENT_MODEL if empty)
# Phase 1: Spec (/spec-first without --full)
SPEC_MODEL=""
# Phase 2: Implement (RED → GREEN, tests + implement + commit)
BUILD_MODEL=""
# Phase 3: Refactor (clean up code, tests must pass)
REFACTOR_MODEL=""
# Retry agent (fixing spec or build/test failures)
RETRY_MODEL=""
# Phase 4: Catch-drift agent (fresh context, Layer 2)
DRIFT_MODEL=""
# Phase 5: Compound/learnings agent
COMPOUND_MODEL=""
# Code-review agent (optional post-build step)
REVIEW_MODEL=""
# Roadmap-triage agent (overnight only)
TRIAGE_MODEL=""

# ── doc-loop-local.sh models ──
# Discovery agent (scans codebase, creates doc-queue.md)
DISCOVERY_MODEL=""
# Documentation agent (documents each queue item — specs + tests)
DOC_MODEL=""

# Example: Opus for spec + refactor (strong reasoning), cheaper for others
# SPEC_MODEL="opus-4.6-thinking"
# BUILD_MODEL="composer-1.5"
# REFACTOR_MODEL="opus-4.6-thinking"
# DRIFT_MODEL="gemini-3-flash"
# COMPOUND_MODEL="gemini-3-flash"

# ─────────────────────────────────────────────
# Documentation Loop Settings (doc-loop-local.sh)
# ─────────────────────────────────────────────

# Max queue items to process per run
MAX_ITEMS=200

# Commit progress every N items
COMMIT_EVERY=5

# Write tests for documented code (true|false)
DOC_WRITE_TESTS=true

# ─────────────────────────────────────────────
# Rate Limit Handling (Claude Code)
# ─────────────────────────────────────────────

# When using CLI_PROVIDER=claude with rate-limited models (e.g., Opus),
# the build scripts detect rate limit errors and retry with backoff.

# Initial wait in seconds when rate limited (doubles each retry)
RATE_LIMIT_BACKOFF=60

# Max total wait in seconds before giving up (default: 5 hours)
RATE_LIMIT_MAX_WAIT=18000

# ─────────────────────────────────────────────
# Dev Server (used by /clean-slate)
# ─────────────────────────────────────────────

# Ports to kill when running /clean-slate (comma-separated)
# Default: 3000,3001,4000,5173,5174,8000,8080,8888
DEV_PORTS="3000,3001,4000,5173,5174,8000,8080,8888"

# Command to start the dev server (auto-detected from package.json if empty)
DEV_CMD=""

# ─────────────────────────────────────────────
# Paths (usually auto-detected)
# ─────────────────────────────────────────────

# Override project directory if needed
# PROJECT_DIR=/path/to/your/project
